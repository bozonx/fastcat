# Dev Mode (true/false)
NUXT_PUBLIC_DEV_MODE=false

# Application Base URL
NUXT_APP_BASE_URL=https://video-editor.example.com

# BloggerDog instance base URL
NUXT_PUBLIC_BLOGGER_DOG_API_URL=https://api.bloggerdog.pro
NUXT_PUBLIC_BLOGGER_DOG_UI_URL=https://bloggerdog.pro
# Fastcat Account base URL
NUXT_PUBLIC_FASTCAT_ACCOUNT_API_URL=https://user-account.fastcat.video
NUXT_PUBLIC_FASTCAT_ACCOUNT_UI_URL=https://user-account.fastcat.video/ui

# Port to run the application on
PORT=3000
