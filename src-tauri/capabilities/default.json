{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**/*",
        "$HOME/**/*"
      ]
    },
    {
      "identifier": "fs-stream:allow-open-read-file-stream",
      "allow": [
        "$APPDATA/**/*",
        "$HOME/**/*"
      ]
    },
    {
      "identifier": "fs-stream:allow-open-write-file-stream",
      "allow": [
        "$APPDATA/**/*",
        "$HOME/**/*"
      ]
    }
  ]
}
